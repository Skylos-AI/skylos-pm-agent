# Supabase credentials.
# Get these from Supabase dashboard → Project Settings → Database / API.
#
# Region locked: us-east-2 (Ohio). See v1.txt Step 4.

# Transaction-mode pooler — port 6543. `pgbouncer=true` disables prepared
# statements so PgBouncer's transaction-mode pooling works correctly.
DATABASE_URL="postgresql://postgres.PROJECT_REF:[YOUR-PASSWORD]@aws-1-us-east-2.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Session-mode pooler — port 5432. Required for Prisma migrations.
DIRECT_URL="postgresql://postgres.PROJECT_REF:[YOUR-PASSWORD]@aws-1-us-east-2.pooler.supabase.com:5432/postgres"

SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...

# service_role bypasses RLS. Agent runtime only — NEVER ship to client.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
